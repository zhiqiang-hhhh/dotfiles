#!/usr/bin/env bash
#
# dothelp - Overview of the commands this dotfiles repo provides.
#
# Lists the command families added by ~/code/dotfiles/bin and the matching
# shell helpers from bashrc.d. For component-specific detail see `help-ch`
# (ClickHouse) and `doris-help` (Doris).

set -euo pipefail

bold=$'\033[1m'; cyan=$'\033[36m'; green=$'\033[32m'; dim=$'\033[2m'; reset=$'\033[0m'

hdr()  { printf '\n%s%s%s\n' "$bold$cyan" "$1" "$reset"; }
row()  { printf '  %s%-26s%s %s\n' "$green" "$1" "$reset" "$2"; }
note() { printf '  %s%s%s\n' "$dim" "$1" "$reset"; }

printf '%sdotfiles commands%s  %s(~/code/dotfiles/bin, on PATH)%s\n' "$bold" "$reset" "$dim" "$reset"

hdr "ClickHouse"
row "deploy-ch"              "Prepare ~/workspace/clickhouse layout + link the built binary"
row "start-ch [TARGET]"      "Start node(s); TARGET = all | node1 | node2 | single"
row "stop-ch [--force] [T]"  "Stop node(s)"
row "restart-ch [TARGET]"    "Restart node(s)"
row "status-ch [TARGET]"     "Show node status (pid/http/tcp ports)"
row "client-ch [NODE] ..."   "Open clickhouse-client against a node (default node1)"
row "configure-ch-s3-minio"  "Point node(s) at local MinIO as an S3 disk + 10Gi cache"
row "help-ch"                "ClickHouse-specific help"

hdr "ZooKeeper"
row "start-zk / stop-zk"     "Start / stop the local ZooKeeper used by ClickHouse cluster"
row "restart-zk / status-zk" "Restart / show ZooKeeper status"

hdr "MinIO (S3 backend for ClickHouse)"
row "deploy-minio"           "Download MinIO + mc, write ~/workspace/minio config"
row "start-minio"            "Start MinIO (api 19900 / console 19901); creates the bucket"
row "stop-minio / restart-minio" "Stop / restart MinIO"
row "status-minio"           "Show MinIO status (ports, bucket)"

hdr "Monitoring (Prometheus + Grafana + node_exporter)"
row "start-monitoring [C]"   "Start all components, or one: prometheus|grafana|node_exporter"
row "stop-monitoring [C]"    "Stop all components, or one"
row "status-monitoring"      "Show component + Doris/ClickHouse wiring status"
row "add-doris-monitoring"   "Provision the Grafana Doris datasource + dashboard"
row "add-clickhouse-monitoring"    "Provision the ClickHouse datasource + overview dashboard"
row "add-clickhouse-s3-monitoring" "Provision the S3-disk + S3/query-performance dashboards"

hdr "Doris  (see help-doris for detail)"
row "help-doris / ports-doris"  "Doris usage and port map"
row "rebuild-doris"             "Destroy and rebuild the local Doris cluster"
row "client-doris [args...]"    "Connect to FE with the mysql client"
row "add-be / restart-be / restart-fe" "Register a BE / restart BE / restart FE"

hdr "Misc"
row "xmlfmt < file.xml"      "Pretty-print XML (xmllint, 4-space); vim uses it for gg=G"
row "clang-format"           "clang-format wrapper using the ldb_018 toolchain"
row "rssh / kitty-remote-fork" "Remote SSH helper / fork a kitty session over SSH"
row "opencode-project"       "Open the current project in opencode"

hdr "Shell shortcuts (bashrc.d, after sourcing your shell)"
note "cch / czk / cminio / cmonitoring   -> cd into the matching ~/workspace dir"
note "Underscore forms of most bin commands exist too, e.g. start_ch, deploy_minio,"
note "configure_ch_s3_minio, add_clickhouse_s3_monitoring."

printf '\n'
