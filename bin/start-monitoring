#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_monitoring-common.sh"

usage() {
    echo "Usage: monitoring-start [prometheus|grafana|node_exporter|all]"
}

start_one() {
    local component="$1"
    monitoring_start_component "$component"
}

target="${1:-all}"

case "$target" in
    all)
        start_one node_exporter
        start_one prometheus
        start_one grafana
        ;;
    prometheus|grafana|node_exporter)
        start_one "$target"
        ;;
    -h|--help)
        usage
        ;;
    *)
        usage >&2
        exit 1
        ;;
esac
