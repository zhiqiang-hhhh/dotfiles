#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_clickhouse-common.sh"

force=""
if [[ "${1:-}" == "--force" ]]; then
    force="--force"
    shift
fi

nodes="$(clickhouse_nodes_from_args "$@")"

for node in $nodes; do
    clickhouse_stop_node "$node" "$force"
done
