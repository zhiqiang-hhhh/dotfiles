#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_doris-common.sh"

host="${1:-127.0.0.1}"
fe_conf="$(doris_fe_conf_path)"
be_conf="$(doris_be_conf_path)"
heartbeat_port="${2:-$(doris_conf_get "$be_conf" "heartbeat_service_port" "9050")}"
query_port="$(doris_conf_get "$fe_conf" "query_port" "9030")"
sql="ALTER SYSTEM ADD BACKEND \"${host}:${heartbeat_port}\";"

if command -v mysql &>/dev/null; then
    mysql -h 127.0.0.1 -P "$query_port" -uroot -e "$sql"
else
    echo "addbe: mysql client not found"
    echo "run manually: mysql -h 127.0.0.1 -P $query_port -uroot -e '$sql'"
    exit 1
fi
