#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_monitoring-common.sh"

usage() {
    echo "Usage: monitoring-stop [prometheus|grafana|node_exporter|all]"
}

stop_one() {
    local component="$1"
    monitoring_stop_component "$component"
}

target="${1:-all}"

case "$target" in
    all)
        stop_one grafana
        stop_one prometheus
        stop_one node_exporter
        ;;
    prometheus|grafana|node_exporter)
        stop_one "$target"
        ;;
    -h|--help)
        usage
        ;;
    *)
        usage >&2
        exit 1
        ;;
esac
